
APP_NAME="Hotel Reservation & Management System"

APP_ENV=local

APP_KEY=

APP_DEBUG=true

APP_URL=http://localhost:8000

APP_TIMEZONE=Africa/Addis_Ababa

APP_LOCALE=en
APP_FALLBACK_LOCALE=en



LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14


# DATABASE

# Driver: mysql | pgsql | sqlite
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hrms_db
DB_USERNAME=root
DB_PASSWORD=

# Connection pool / timeout settings (seconds)
DB_TIMEOUT=60
DB_STRICT=true
CACHE_DRIVER=file

CACHE_PREFIX=hrms_cache

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0


# SESSION

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=database
QUEUE_RETRY_AFTER=90
QUEUE_FAILED_DRIVER=database-uuids
QUEUE_DEFAULT=default

QUEUE_HIGH=high
QUEUE_LOW=low


# -----------------------------------------------------------------------------
# MAIL
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password

# Encryption: tls | ssl | null
MAIL_ENCRYPTION=tls

# [REQUIRED] From address shown to recipients
MAIL_FROM_ADDRESS="noreply@hrms.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional reply-to address (defaults to MAIL_FROM_ADDRESS if blank)
MAIL_REPLY_TO_ADDRESS=
MAIL_REPLY_TO_NAME=


# -----------------------------------------------------------------------------
# FILESYSTEM / STORAGE
# -----------------------------------------------------------------------------

# Default disk: local | public | s3
FILESYSTEM_DISK=local

# AWS S3 (used when FILESYSTEM_DISK=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=


# -----------------------------------------------------------------------------
# FRONTEND (Vue 3 / Vite)
# -----------------------------------------------------------------------------

# [REQUIRED] URL of the Vue frontend — used in CORS and email links
FRONTEND_URL=http://localhost:5173


# -----------------------------------------------------------------------------
# SANCTUM / CORS
# -----------------------------------------------------------------------------

# Comma-separated list of domains allowed to make stateful requests
# Include all frontend origins (with port) that use cookie-based auth
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000

# Token expiry in minutes (null = never expires)
SANCTUM_TOKEN_EXPIRATION=null


# -----------------------------------------------------------------------------
# CHECK-IN QR CODE
# -----------------------------------------------------------------------------

# [REQUIRED] Secret used to HMAC-sign QR check-in tokens
# Generate with: php artisan tinker --execute="echo bin2hex(random_bytes(32));"
CHECKIN_QR_SECRET=

# QR token validity window in hours
CHECKIN_QR_TTL_HOURS=24


# -----------------------------------------------------------------------------
# TELEBIRR PAYMENT GATEWAY
# -----------------------------------------------------------------------------
# Obtain credentials from Ethio Telecom developer portal.
# Sandbox base URL: https://196.188.120.3:38443/apiaccess
# Production base URL: provided by Ethio Telecom

TELEBIRR_APP_ID=
TELEBIRR_APP_KEY=
TELEBIRR_PUBLIC_KEY=
TELEBIRR_SHORT_CODE=
TELEBIRR_BASE_URL=https://196.188.120.3:38443/apiaccess
TELEBIRR_NOTIFY_URL="${APP_URL}/api/payments/telebirr/webhook"
TELEBIRR_RETURN_URL="${FRONTEND_URL}/bookings/payment-result"

# CBE BIRR PAYMENT GATEWAY

CBE_BIRR_MERCHANT_ID=
CBE_BIRR_API_KEY=
CBE_BIRR_SECRET_KEY=
CBE_BIRR_BASE_URL=https://api.cbebirr.com

CBE_BIRR_NOTIFY_URL="${APP_URL}/api/payments/cbebirr/webhook"
CBE_BIRR_RETURN_URL="${FRONTEND_URL}/bookings/payment-result"


# BROADCASTING (optional — for real-time features)

BROADCAST_DRIVER=null

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1


# MAINTENANCE MODE
MAINTENANCE_SECRET=


# ============================================================================
# TELEGRAM BOT - USER BOT
# ============================================================================

# [REQUIRED] Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# [REQUIRED] Webhook URL (your app URL + webhook endpoint)
# For local development with ngrok: https://your-ngrok-url.ngrok.io/api/telegram-webhook
# For production: https://yourdomain.com/api/telegram-webhook
TELEGRAM_WEBHOOK_URL=

# Optional: Bot username (without @)
TELEGRAM_BOT_USERNAME=

# Optional: Enable debug mode (true/false)
TELEGRAM_DEBUG=false

# ============================================================================
# TELEGRAM BOT - ADMIN BOT (Optional - for separate admin bot)
# ============================================================================

# Admin bot token (leave empty if not using separate admin bot)
TELEGRAM_ADMIN_BOT_TOKEN=

# Admin bot webhook URL
TELEGRAM_ADMIN_WEBHOOK_URL=

# Admin bot username (without @)
TELEGRAM_ADMIN_BOT_USERNAME=

# Async requests (true/false)
TELEGRAM_ASYNC_REQUESTS=false
