
# Local dev:   http://localhost:8000/api
# Production:  https://api.hrms.com/api
VITE_API_URL=http://localhost:8000/api


VITE_APP_NAME="Hotel Reservation & Management System"

# Short name used in the sidebar / navbar
VITE_APP_SHORT_NAME=HR&MS

# Current environment label (informational only, not a security boundary)
# Values: development | staging | production
VITE_APP_ENV=development


# -----------------------------------------------------------------------------
# CURRENCY
# -----------------------------------------------------------------------------

# ISO 4217 currency code displayed throughout the UI
VITE_CURRENCY=ETB

# Currency symbol rendered next to prices
VITE_CURRENCY_SYMBOL=ETB


# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------

# Set to true to enable Vue Devtools in production builds (not recommended)
VITE_DEVTOOLS=false
